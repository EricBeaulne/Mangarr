# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/

# ── Node ─────────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.vite/
# Keep frontend/dist OUT of ignore — the multi-stage build generates its own
# fresh dist, but excluding node_modules is the critical one

# ── Git / IDE ────────────────────────────────────────────────────────────────
.git/
.gitignore
.github/
.vscode/
.idea/

# ── Runtime data (never belongs in an image) ─────────────────────────────────
data/
*.db
*.sqlite

# ── Misc ─────────────────────────────────────────────────────────────────────
*.md
*.log
.env
.env.*
!.env.example
frontend/Dockerfile
